<header class="navbar">
  <a href="/" class="navbar-brand">App</a>
  <nav class="nav-links">
    <!-- user variable comes from the global middleware in app.ts -->
    <% if (typeof user !== 'undefined' && user) { %>
      <span class="nav-link" style="color: var(--text-color);">Welcome, <strong><%= user.email %></strong></span>
      <a href="/profile" class="nav-link <%= typeof path !== 'undefined' && path === '/profile' ? 'active' : '' %>">Profile</a>
      <form action="/logout" method="POST" style="display:inline;">
        <button type="submit" class="btn btn-secondary" style="padding: 0.25rem 0.75rem; font-size: 0.875rem;">Logout</button>
      </form>
    <% } else { %>
      <a href="/login" class="nav-link <%= typeof path !== 'undefined' && path === '/login' ? 'active' : '' %>">Login</a>
    <% } %>
  </nav>
</header>

<!-- Global messages support -->
<div class="container" style="padding-bottom: 0; margin-bottom: 0;">
  <% if (typeof err !== 'undefined' && err) { %>
    <div class="alert alert-error">
      <% if (err === 'invalid') { %>Invalid email or password.<% } %>
      <% if (err === 'rate_limit') { %>Too many login attempts, please try again later.<% } %>
      <% if (err !== 'invalid' && err !== 'rate_limit') { %><%= err %><% } %>
    </div>
  <% } %>
  
  <% if (typeof msg !== 'undefined' && msg) { %>
    <div class="alert alert-success">
      <% if (msg === 'registered') { %>Registration successful. Please log in.<% } %>
      <% if (msg === 'logged_out') { %>You have been successfully logged out.<% } %>
      <% if (msg !== 'registered' && msg !== 'logged_out') { %><%= msg %><% } %>
    </div>
  <% } %>
</div>
